# Themes at https://iterm2colorschemes.com/
theme = dark:Apple System Colors,light:Apple System Colors Light
font-family = Pragmata Pro Liga
font-size = 10

window-decoration = false
gtk-titlebar = false

keybind = ctrl+enter=unbind
keybind = ctrl+-=unbind
keybind = ctrl+shift+-=decrease_font_size:1
keybind = ctrl+shift++=increase_font_size:1