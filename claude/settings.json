{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Read(/nix/store/**)",
      "Bash(ls /nix/store/*)",
      "Bash(cat /nix/store/*)",
      "Bash(find /nix/store/*)",
      "Bash(grep *)",
      "Bash(awk *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.cache/claude-notify && touch ~/.cache/claude-notify/active"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify 'Claude needs input' 'Waiting for your response'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify 'Claude finished' 'Task complete'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sleep 2; if [ -s errors.err ]; then cat errors.err; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "theme": "auto",
  "skipAutoPermissionPrompt": true
}
